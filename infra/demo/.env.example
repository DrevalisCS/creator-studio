# Demo instance env — mirror to .env on the VPS. Values here are
# placeholder; the bring-up script at infra/demo/bring_up.sh fills
# ENCRYPTION_KEY + LICENSE_JWT with real values at deploy time.

# Required
ENCRYPTION_KEY=<replaced-at-deploy>
LICENSE_SERVER_URL=https://license.drevalis.com

# Demo API auth — allows seed + screenshot scripts to call the API
# without going through the license activation flow for side doors.
# Keep this token secret (it's the same env var real customers use).
API_AUTH_TOKEN=<replaced-at-deploy>

# Optional — keeps logs readable during demo capture
DEBUG=false
